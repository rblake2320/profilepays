# ─────────────────────────────────────────────────────────────────────────────
# ProfilePays — docker-compose environment
# Copy this file to .env next to docker-compose.yml and fill in your values.
# NEVER commit .env to version control.
# For local (non-Docker) backend development use backend/.env.example instead.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (consumed by the postgres service and the API) ─────────────────
DB_USERNAME=profilepays_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_DATABASE=profilepays_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_64_char_random_string_here
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_char_random_string_here

# ─── Stripe Payments (payments module — not yet wired into the app) ──────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Build-time API base URL. Default /api/v1 uses the nginx same-origin proxy.
VITE_API_URL=/api/v1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origin the API allows credentials from (the public frontend URL)
FRONTEND_URL=http://localhost
