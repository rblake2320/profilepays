# Environment Variables Template
# Copy this file to .env and fill in your values

# ===== Database Configuration =====
DATABASE_URL="postgresql://username:password@localhost:5432/profilepays"
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_USERNAME="profilepays_user"
DATABASE_PASSWORD="secure_password"
DATABASE_NAME="profilepays"

# ===== Authentication =====
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRATION="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_EXPIRATION="30d"

# ===== OAuth Configuration =====
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Facebook OAuth
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ===== Payment Processing =====
# Stripe (for subscriptions and business payments)
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# PayPal (for user payouts)
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox" # or "live" for production

# ===== Email Service =====
EMAIL_SERVICE="sendgrid" # or "mailgun", "ses"
EMAIL_API_KEY="your-email-service-api-key"
EMAIL_FROM="noreply@profilepays.com"
EMAIL_TEMPLATES_DIR="./templates/email"

# ===== File Storage =====
# AWS S3 for profile pictures and assets
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="profilepays-assets"

# Alternative: Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ===== Redis (for caching and sessions) =====
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ===== Application Configuration =====
NODE_ENV="development" # development, production, test
PORT=3000
FRONTEND_URL="http://localhost:3001"
BACKEND_URL="http://localhost:3000"
API_PREFIX="/api/v1"

# ===== Monitoring and Analytics =====
SENTRY_DSN="your-sentry-dsn"
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"

# ===== Feature Flags =====
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ===== Security =====
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN="http://localhost:3001"
COOKIE_SECRET="your-cookie-secret"

# ===== Development Tools =====
LOG_LEVEL="debug" # error, warn, info, debug
ENABLE_SWAGGER=true
ENABLE_GRAPHQL_PLAYGROUND=true

# ===== Testing =====
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/profilepays_test"