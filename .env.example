# ─────────────────────────────────────────────────────────────────────────────
# ProfilePays Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:3000
API_PREFIX=/api/v1

# ─── Database (PostgreSQL — used in production/Docker) ───────────────────────
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=profilepays_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_DATABASE=profilepays_db
DB_SSL=false
# Full URL form (alternative)
DATABASE_URL=postgresql://profilepays_user:CHANGE_ME@postgres:5432/profilepays_db

# ─── Database (SQLite — used in local development) ───────────────────────────
# DB_TYPE=better-sqlite3
# SQLITE_PATH=./profilepays.sqlite

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_64_char_random_string_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_char_random_string_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── PayPal Payouts ──────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
PAYPAL_MODE=live

# ─── Email Service ───────────────────────────────────────────────────────────
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=CHANGE_ME
EMAIL_FROM=noreply@profilepays.com

# ─── AWS S3 (for proof screenshots) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET=profilepays-assets

# ─── OAuth (optional social login) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ─── Frontend ────────────────────────────────────────────────────────────────
# In production with Nginx proxy, /api/ is proxied to backend
VITE_API_URL=http://localhost/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ─── Security ────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=CHANGE_ME_optional

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SWAGGER=true

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
