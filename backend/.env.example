# Application Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_db_password
DB_NAME=profilepays
# Set DB_SSL=true to require TLS to Postgres
# (DB_SSL_REJECT_UNAUTHORIZED=false permits self-signed certificates)
DB_SSL=false

# JWT Configuration — REQUIRED, the app refuses to boot without it.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Stripe Configuration (payments module — not yet wired into the app)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
