{
  "name": "profilepays",
  "version": "0.1.0",
  "private": true,
  "description": "A social-advertising platform that pays users for temporarily swapping their profile pictures with brand-sponsored images",
  "keywords": [
    "social-advertising",
    "profile-pictures",
    "marketing",
    "brand-sponsorship",
    "react",
    "nestjs",
    "typescript"
  ],
  "author": "rblake2320",
  "license": "MIT",
  "homepage": "https://github.com/rblake2320/profilepays#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rblake2320/profilepays.git"
  },
  "bugs": {
    "url": "https://github.com/rblake2320/profilepays/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "prepare": "husky install",
    "setup": "./setup.sh",
    "install:all": "npm install && npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run start:dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test:e2e": "cd frontend && npm run test:e2e",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "lint:fix": "npm run lint:frontend -- --fix && npm run lint:backend -- --fix",
    "lint:check": "npm run lint:frontend -- --max-warnings 0 && npm run lint:backend -- --max-warnings 0",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "type-check": "npm run type-check:frontend && npm run type-check:backend",
    "type-check:frontend": "cd frontend && npm run type-check",
    "type-check:backend": "cd backend && npm run type-check",
    "test:watch": "npm run test:frontend -- --watch",
    "test:coverage": "npm run test:frontend -- --coverage && npm run test:backend -- --coverage",
    "test:ci": "npm run test:frontend -- --ci --coverage --watchAll=false && npm run test:backend -- --ci --coverage --watchAll=false",
    "quality": "npm run type-check && npm run lint:check && npm run test:ci && npm run format:check",
    "pre-commit": "npm run format && npm run lint:fix && npm run test",
    "validate": "npm run quality && npm run build",
    "clean": "npm run clean:frontend && npm run clean:backend && npm run clean:root",
    "clean:frontend": "cd frontend && rm -rf dist node_modules",
    "clean:backend": "cd backend && rm -rf dist node_modules",
    "clean:root": "rm -rf node_modules",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "db:setup": "cd backend && npm run migration:run && npm run seed:run",
    "db:reset": "cd backend && npm run migration:revert && npm run migration:run && npm run seed:run",
    "release": "standard-version",
    "precommit": "lint-staged",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "babel-jest": "^30.1.2",
    "concurrently": "^8.2.2",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-transform-stub": "^2.0.0",
    "jest-watch-typeahead": "^3.0.1",
    "lint-staged": "^15.2.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "chore",
          "revert",
          "build",
          "ci"
        ]
      ]
    }
  },
  "standard-version": {
    "scripts": {
      "prebump": "npm test",
      "precommit": "git add CHANGELOG.md"
    }
  },
  "dependencies": {
    "jest-environment-jsdom": "^30.4.1",
    "react-dom": "^19.2.6"
  }
}
