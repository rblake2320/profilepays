FROM node:18-alpine AS development

WORKDIR /app

COPY backend/package*.json ./

RUN npm ci

COPY backend/ .

EXPOSE 3000

CMD ["npm", "run", "start:dev"]

# Production stage
FROM node:18-alpine AS production

WORKDIR /app

COPY backend/package*.json ./

RUN npm ci --only=production

COPY backend/ .

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start:prod"]
